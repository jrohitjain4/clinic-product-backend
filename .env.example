PORT=5000

# --- Option A: Render PostgreSQL (production / remote) ---
# Render Dashboard → your Postgres → Connect → copy **External** Database URL
# Must include sslmode for external connections, e.g.:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST.oregon-postgres.render.com/DATABASE?sslmode=require"
#
# If you see "Can't reach database server":
# 1. Render dashboard → Postgres → Resume / Restore if suspended
# 2. Copy a fresh External URL (hostname changes if DB was recreated)
# 3. Free tier DB sleeps after inactivity — first request may take 30–60s

# --- Option B: Local Docker (recommended for dev) ---
# docker compose up -d
DATABASE_URL="postgresql://clinic:clinic123@localhost:5432/clinic_saas_db?schema=public"

JWT_SECRET="change-this-to-a-long-random-secret-in-production"
FRONTEND_URL=http://localhost:5173,https://your-app.vercel.app
