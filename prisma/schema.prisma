datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  DOCTOR
  PATIENT
  PORTER
  STAFF
}

enum ClinicStatus {
  IN_PROGRESS
  TRIAL
  TRIAL_EXPIRED
  TRIAL_COMPLETED_NOT_UPGRADED
  UPGRADED
  FAILED
}

model Clinic {
  id                    String                 @id @default(uuid())
  name                  String
  subdomain             String?                @unique
  gstNo                 String?
  address               String?
  phone                 String?
  status                ClinicStatus           @default(IN_PROGRESS)
  packageId             String?
  package               SubscriptionPackage?   @relation(fields: [packageId], references: [id])
  packageStartsAt       DateTime?
  packageExpiresAt      DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  users                 User[]
  departments           Department[]
  designations          Designation[]
  doctors               Doctor[]
  staffs                Staff[]
  patients              Patient[]
  appointments          Appointment[]
  services              Service[]
  specializations       Specialization[]
  holidays              Holiday[]
  payrolls              Payroll[]
  expenses              Expense[]
  expenseCategories     ExpenseCategory[]
  attendances           Attendance[]
  leaveTypes            LeaveType[]
  leaves                Leave[]
  prescriptions         Prescription[]
  prescriptionMedicines PrescriptionMedicine[]
  clinicRoles           ClinicRole[]
  invoices              Invoice[]
  invoiceItems          InvoiceItem[]
  products              Product[]
}

model SubscriptionPackage {
  id              String   @id @default(uuid())
  name            String
  price           Float
  durationInDays  Int
  maxDoctors      Int
  maxPatients     Int
  maxAppointments Int
  isActive        Boolean  @default(true)
  clinics         Clinic[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  fullName     String
  dob          DateTime?
  age          Int?
  gender       String?
  role         Role
  clinicId     String?
  clinic       Clinic?   @relation(fields: [clinicId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Department {
  id            String         @id @default(uuid())
  name          String
  description   String?
  status        String         @default("Active")
  clinicId      String
  clinic        Clinic         @relation(fields: [clinicId], references: [id])
  designations  Designation[]
  doctors       Doctor[]
  staffs        Staff[]
  appointments  Appointment[]
  services      Service[]
  prescriptions Prescription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Designation {
  id           String      @id @default(uuid())
  name         String
  type         String      @default("Staff")
  description  String?
  status       String      @default("Active")
  clinicId     String
  clinic       Clinic      @relation(fields: [clinicId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  doctors      Doctor[]
  staffs       Staff[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Staff {
  id            String       @id @default(uuid())
  staffCode     String?
  fullName      String
  role          String
  profileImage  String?
  phone         String?
  email         String?
  dob           DateTime?
  gender        String?
  bloodGroup    String?
  address1      String?
  address2      String?
  country       String?
  state         String?
  city          String?
  pincode       String?
  dateOfJoining DateTime?
  status        String       @default("Active")
  designationId String?
  designation   Designation? @relation(fields: [designationId], references: [id])
  departmentId  String?
  department    Department?  @relation(fields: [departmentId], references: [id])
  clinicId      String
  clinic        Clinic       @relation(fields: [clinicId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  payrolls      Payroll[]
}

model Doctor {
  id                      String          @id @default(uuid())
  fullName                String
  username                String?
  phone                   String?
  email                   String?
  dob                     DateTime?
  yearOfExperience        Int?
  medicalLicenseNumber    String?
  languagesSpoken         String[]
  bloodGroup              String?
  gender                  String?
  bio                     String?
  featureOnWebsite        Boolean         @default(false)
  profileImage            String?
  address1                String?
  address2                String?
  country                 String?
  city                    String?
  state                   String?
  pincode                 String?
  appointmentType         String?
  acceptBookingsInAdvance Int?
  appointmentDuration     Int?
  consultationCharge      Float?
  maxBookingsPerSlot      Int?
  displayOnBookingPage    Boolean         @default(false)
  educations              Json?
  awards                  Json?
  certifications          Json?
  schedules               Json?
  status                  String          @default("Active")
  departmentId            String?
  department              Department?     @relation(fields: [departmentId], references: [id])
  designationId           String?
  designation             Designation?    @relation(fields: [designationId], references: [id])
  specializationId        String?
  specialization          Specialization? @relation(fields: [specializationId], references: [id])
  clinicId                String
  clinic                  Clinic          @relation(fields: [clinicId], references: [id])
  patients                Patient[]
  appointments            Appointment[]
  prescriptions           Prescription[]
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
}

model Patient {
  id              String         @id @default(uuid())
  patientCode     String?
  firstName       String
  lastName        String
  profileImage    String?
  phone           String?
  email           String?
  dob             DateTime?
  gender          String?
  bloodGroup      String?
  status          String         @default("Active")
  address1        String?
  address2        String?
  country         String?
  state           String?
  city            String?
  pincode         String?
  primaryDoctorId String?
  primaryDoctor   Doctor?        @relation(fields: [primaryDoctorId], references: [id])
  lastVisitedAt   DateTime?
  vitals          Json?
  clinicId        String
  clinic          Clinic         @relation(fields: [clinicId], references: [id])
  appointments    Appointment[]
  prescriptions   Prescription[]
  invoices        Invoice[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([clinicId])
  @@index([primaryDoctorId])
  @@index([status])
}

model Appointment {
  id              String         @id @default(uuid())
  appointmentCode String?
  patientId       String
  patient         Patient        @relation(fields: [patientId], references: [id])
  doctorId        String
  doctor          Doctor         @relation(fields: [doctorId], references: [id])
  departmentId    String?
  department      Department?    @relation(fields: [departmentId], references: [id])
  scheduledAt     DateTime
  endAt           DateTime?
  mode            String         @default("In-person")
  appointmentType String?
  status          String         @default("Schedule")
  reason          String?
  location        String?
  clinicId        String
  clinic          Clinic         @relation(fields: [clinicId], references: [id])
  prescriptions   Prescription[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([clinicId])
  @@index([patientId])
  @@index([doctorId])
  @@index([scheduledAt])
  @@index([status])
}

model Service {
  id           String        @id @default(uuid())
  serviceName  String
  departmentId String
  department   Department    @relation(fields: [departmentId], references: [id])
  price        Float
  status       String        @default("Active")
  clinicId     String
  clinic       Clinic        @relation(fields: [clinicId], references: [id])
  invoiceItems InvoiceItem[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([clinicId])
  @@index([departmentId])
  @@index([status])
}

model Specialization {
  id          String   @id @default(uuid())
  name        String
  description String?
  image       String?
  status      String   @default("Active")
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  doctors     Doctor[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clinicId])
  @@index([status])
}

model Holiday {
  id          String    @id @default(uuid())
  title       String
  description String?
  date        DateTime
  endDate     DateTime?
  dayName     String?
  clinicId    String
  clinic      Clinic    @relation(fields: [clinicId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clinicId])
}

model Payroll {
  id               String   @id @default(uuid())
  staffId          String
  staff            Staff    @relation(fields: [staffId], references: [id])
  netSalary        Float
  basicSalary      Float    @default(0)
  da               Float    @default(0)
  hra              Float    @default(0)
  conveyance       Float    @default(0)
  medicalAllowance Float    @default(0)
  otherEarnings    Float    @default(0)
  tds              Float    @default(0)
  esi              Float    @default(0)
  pf               Float    @default(0)
  profTax          Float    @default(0)
  labourWelfare    Float    @default(0)
  otherDeductions  Float    @default(0)
  status           String   @default("Paid")
  clinicId         String
  clinic           Clinic   @relation(fields: [clinicId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([clinicId])
  @@index([staffId])
}

model Expense {
  id            String   @id @default(uuid())
  name          String
  category      String
  amount        Float
  date          DateTime
  purchasedBy   String
  paymentMethod String
  status        String   @default("New")
  clinicId      String
  clinic        Clinic   @relation(fields: [clinicId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([clinicId])
}

model ExpenseCategory {
  id        String   @id @default(uuid())
  name      String
  status    String   @default("Active")
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
}

model ClinicRole {
  id          String   @id @default(uuid())
  name        String
  permissions Json     @default("[]")
  status      String   @default("Active")
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clinicId])
}

model Attendance {
  id           String   @id @default(uuid())
  date         DateTime
  employeeId   String
  employeeType String // "DOCTOR" or "STAFF"
  status       String // "PRESENT", "ABSENT", "HALF_DAY"
  markedBy     String   @default("ADMIN") // "ADMIN", "SELF", "SYSTEM"
  clinicId     String
  clinic       Clinic   @relation(fields: [clinicId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([clinicId, employeeId, employeeType, date])
  @@index([clinicId])
  @@index([employeeId])
}

model LeaveType {
  id        String   @id @default(uuid())
  name      String
  quota     Int      @default(0)
  status    String   @default("Active")
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
}

model Leave {
  id            String   @id @default(uuid())
  clinicId      String
  clinic        Clinic   @relation(fields: [clinicId], references: [id])
  employeeId    String
  employeeType  String // DOCTOR or STAFF
  leaveTypeId   String
  leaveTypeName String
  startDate     DateTime
  endDate       DateTime
  days          Int      @default(1)
  reason        String?  @default("")
  status        String   @default("APPLIED") // APPLIED, APPROVED, REJECTED
  appliedOn     DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([clinicId])
  @@index([employeeId])
}

model Prescription {
  id               String       @id @default(uuid())
  prescriptionCode String?
  patientId        String
  patient          Patient      @relation(fields: [patientId], references: [id])
  doctorId         String
  doctor           Doctor       @relation(fields: [doctorId], references: [id])
  appointmentId    String?
  appointment      Appointment? @relation(fields: [appointmentId], references: [id])
  departmentId     String?
  department       Department?  @relation(fields: [departmentId], references: [id])
  advice           String?
  followUpDate     DateTime?
  followUpNotes    String?
  status           String       @default("Active")
  clinicId         String
  clinic           Clinic       @relation(fields: [clinicId], references: [id])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  medicines PrescriptionMedicine[]

  @@index([clinicId])
  @@index([patientId])
  @@index([doctorId])
}

model PrescriptionMedicine {
  id             String       @id @default(uuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicineName   String
  dosage         String?
  frequency      String?
  duration       String?
  timings        String? // e.g., "After meal", "Before meal"
  clinicId       String
  clinic         Clinic       @relation(fields: [clinicId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([prescriptionId])
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceCode   String?
  patientId     String
  patient       Patient       @relation(fields: [patientId], references: [id])
  invoiceDate   DateTime
  dueDate       DateTime
  tax           Float         @default(0)
  discount      Float         @default(0)
  subTotal      Float         @default(0)
  totalAmount   Float
  paymentMethod String?
  paymentStatus String        @default("Pending") // Pending, Paid, Partially Paid
  otherInfo     String?
  clinicId      String
  clinic        Clinic        @relation(fields: [clinicId], references: [id])
  items         InvoiceItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([clinicId])
  @@index([patientId])
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  serviceId   String?
  service     Service? @relation(fields: [serviceId], references: [id])
  description String?
  quantity    Int      @default(1)
  unitCost    Float
  amount      Float
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([invoiceId])
  @@index([serviceId])
  @@index([clinicId])
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  key         String?
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clinicId])
}
