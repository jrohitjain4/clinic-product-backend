datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  DOCTOR
  PATIENT
  PORTER
}

enum ClinicStatus {
  IN_PROGRESS
  TRIAL
  TRIAL_EXPIRED
  TRIAL_COMPLETED_NOT_UPGRADED
  UPGRADED
  FAILED
}

model Clinic {
  id               String               @id @default(uuid())
  name             String
  subdomain        String?              @unique
  gstNo            String?
  address          String?
  phone            String?
  status           ClinicStatus         @default(IN_PROGRESS)
  packageId        String?
  package          SubscriptionPackage? @relation(fields: [packageId], references: [id])
  packageStartsAt  DateTime?
  packageExpiresAt DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  users            User[]
}

model SubscriptionPackage {
  id              String   @id @default(uuid())
  name            String
  price           Float
  durationInDays  Int
  maxDoctors      Int
  maxPatients     Int
  maxAppointments Int
  isActive        Boolean  @default(true)
  clinics         Clinic[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  fullName     String
  dob          DateTime?
  age          Int?
  gender       String?
  role         Role
  clinicId     String?
  clinic       Clinic?   @relation(fields: [clinicId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
