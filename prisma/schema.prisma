datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  DOCTOR
  PATIENT
  PORTER
  STAFF
}

enum ClinicStatus {
  IN_PROGRESS
  TRIAL
  TRIAL_EXPIRED
  TRIAL_COMPLETED_NOT_UPGRADED
  UPGRADED
  FAILED
}

model Clinic {
  id                    String                 @id @default(uuid())
  name                  String
  username              String?                @unique
  ownerName             String?
  ownerEmail            String?
  whatsappNumber        String?
  phone                 String?
  addressLine1          String?
  addressLine2          String?
  district              String?
  city                  String?
  state                 String?
  country               String?
  pincode               String?
  gstNumber             String?
  emergencyContact      String?
  doctorCount           Int?
  status                ClinicStatus           @default(IN_PROGRESS)
  onboardingStep        Int                    @default(0)
  packageId             String?
  package               SubscriptionPackage?   @relation(fields: [packageId], references: [id])
  packageStartsAt       DateTime?
  packageExpiresAt      DateTime?
  isTrialUsed           Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  users                 User[]
  departments           Department[]
  designations          Designation[]
  doctors               Doctor[]
  staffs                Staff[]
  patients              Patient[]
  appointments          Appointment[]
  services              Service[]
  specializations       Specialization[]
  holidays              Holiday[]
  payrolls              Payroll[]
  expenses              Expense[]
  expenseCategories     ExpenseCategory[]
  attendances           Attendance[]
  leaveTypes            LeaveType[]
  leaves                Leave[]
  prescriptions         Prescription[]
  prescriptionMedicines PrescriptionMedicine[]
  clinicRoles           ClinicRole[]
  invoices              Invoice[]
  invoiceItems          InvoiceItem[]
  products              Product[]
  notifications         Notification[]
  landingPage           LandingPage?
  workingDaysConfig     WorkingDaysConfig?
  tickets               Ticket[]
  todos                 Todo[]
  notes                 Note[]
  labCategories         LabCategory[]
  labTests              LabTest[]
  labBookings           LabBooking[]
  pharmacyCategories    PharmacyCategory[]
  medicines             Medicine[]
  pharmacyInvoices      PharmacyInvoice[]
  consultations         Consultation[]
  therapyPlans          TherapyPlan[]
}

model LandingPage {
  id             String   @id @default(uuid())
  clinicId       String   @unique
  clinic         Clinic   @relation(fields: [clinicId], references: [id])
  tagline        String?
  whatsapp       String?
  email          String?
  facebook       String?
  instagram      String?
  about          String?
  established    Int?
  patientsServed String?
  experience     Int?
  mapUrl         String?
  directionsUrl  String?
  reviews        Json?    @default("[]")
  gallery        Json?    @default("[]")
  services       Json?    @default("[]")
  faqs           Json?    @default("[]")
  timetable      Json?    @default("{}")
  headerImage    String?
  aboutImage     String?
  gmbUrl         String?
  logo           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([clinicId])
}

model SubscriptionPackage {
  id              String   @id @default(uuid())
  name            String
  price           Float
  durationInDays  Int
  isActive        Boolean  @default(true)
  maxDoctors      Int?
  maxPatients     Int?
  maxAppointments Int?
  clinics         Clinic[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  username     String?   @unique
  phone        String?   @unique
  passwordHash String
  fullName     String
  dob          DateTime?
  age          Int?
  gender       String?
  role         Role
  clinicId     String?
  clinic       Clinic?   @relation(fields: [clinicId], references: [id])
  profileImage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Department {
  id             String         @id @default(uuid())
  departmentCode String?
  name           String
  description    String?
  iconUrl        String?
  status         String         @default("Active")
  clinicId      String
  clinic        Clinic         @relation(fields: [clinicId], references: [id])
  designations  Designation[]
  doctors       Doctor[]
  staffs        Staff[]
  appointments  Appointment[]
  services      Service[]
  prescriptions Prescription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Designation {
  id           String      @id @default(uuid())
  name         String
  type         String      @default("Staff")
  description  String?
  status       String      @default("Active")
  clinicId     String
  clinic       Clinic      @relation(fields: [clinicId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  doctors      Doctor[]
  staffs       Staff[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Staff {
  id            String       @id @default(uuid())
  staffCode     String?
  fullName      String
  role          String
  profileImage  String?
  phone         String?
  email         String?
  dob           DateTime?
  gender        String?
  bloodGroup    String?
  address1      String?
  address2      String?
  country       String?
  state         String?
  city          String?
  pincode       String?
  dateOfJoining DateTime?
  status        String       @default("Active")
  designationId String?
  designation   Designation? @relation(fields: [designationId], references: [id])
  departmentId  String?
  department    Department?  @relation(fields: [departmentId], references: [id])
  clinicId      String
  clinic        Clinic       @relation(fields: [clinicId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  payrolls      Payroll[]
}

model Doctor {
  id                      String          @id @default(uuid())
  doctorCode              String?
  fullName                String
  username                String?
  phone                   String?
  alternateMobile         String?
  email                   String?
  dob                     DateTime?
  yearOfExperience        Int?
  medicalLicenseNumber    String?
  languagesSpoken         String[]
  bloodGroup              String?
  gender                  String?
  bio                     String?
  featureOnWebsite        Boolean         @default(false)
  profileImage            String?
  address1                String?
  address2                String?
  country                 String?
  city                    String?
  state                   String?
  pincode                 String?
  appointmentType         String?
  acceptBookingsInAdvance Int?
  appointmentDuration     Int?
  consultationCharge      Float?
  maxBookingsPerSlot      Int?
  displayOnBookingPage    Boolean         @default(false)
  educations              Json?
  awards                  Json?
  certifications          Json?
  schedules               Json?
  status                  String          @default("Active")
  doctorType              String?         @default("regular")
  departmentId            String?
  department              Department?     @relation(fields: [departmentId], references: [id])
  maritalStatus           String?
  qualification           String?
  signatureImage          String?
  medicalRegCertificate   String?
  qualificationCertificate String?
  aadhaarCard             String?
  aadhaarCardBack         String?
  panCard                 String?
  followUpEnabled         Boolean         @default(false)
  followUpValidityDays    Int?
  freeFollowUpLimit       Int?
  followUpFee             Float?
  designationId           String?
  designation             Designation?    @relation(fields: [designationId], references: [id])
  specializations         Specialization[]
  clinicId                String
  clinic                  Clinic          @relation(fields: [clinicId], references: [id])
  appointments            Appointment[]
  prescriptions           Prescription[]
  payrolls                Payroll[]
  consultations           Consultation[]
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
}

model Patient {
  id              String         @id @default(uuid())
  patientCode     String?
  firstName       String
  middleName      String?
  lastName        String
  profileImage    String?
  phone           String?
  alternateMobile String?
  email           String?
  dob             DateTime?
  age             Int?
  gender          String?
  bloodGroup      String?
  maritalStatus   String?
  occupation      String?
  aadhaarNumber   String?
  passportNumber  String?
  referredBy      String?
  emergencyContactName String?
  emergencyContactRelation String?
  emergencyContactPhone String?
  status          String         @default("Active")
  address1        String?
  address2        String?
  country         String?
  state           String?
  city            String?
  pincode         String?
  lastVisitedAt   DateTime?
  vitals          Json?
  clinicId        String
  clinic          Clinic         @relation(fields: [clinicId], references: [id])
  appointments    Appointment[]
  prescriptions   Prescription[]
  invoices        Invoice[]
  labBookings     LabBooking[]
  pharmacyInvoices PharmacyInvoice[]
  consultations   Consultation[]
  suggestIPD      Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([clinicId])
  @@index([status])
}

model Appointment {
  id              String         @id @default(uuid())
  appointmentCode String?
  patientId       String?
  patient         Patient?       @relation(fields: [patientId], references: [id], onDelete: SetNull)
  doctorId        String?
  doctor          Doctor?        @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  departmentId    String?
  department      Department?    @relation(fields: [departmentId], references: [id])
  scheduledAt     DateTime
  endAt           DateTime?
  mode            String         @default("In-person") // In-person (Offline), Online, Home Visit
  appointmentType String?        // "regular" | "therapy"
  onlineLink      String?
  homeAddress     String?
  therapyCategoryId String?
  therapyId       String?
  consultationFee Float?
  discountType    String?        // "percentage" | "fixed" | "none"
  discountValue   Float?
  discountAmount  Float?
  finalFee        Float?
  whatsappNotification Boolean?  @default(false)
  status          String         @default("Schedule")
  reason          String?
  location        String?
  clinicId        String
  clinic          Clinic         @relation(fields: [clinicId], references: [id])
  prescriptions   Prescription[]
  notes           Note[]
  parentAppointmentId String?
  parentAppointment   Appointment? @relation("FollowUps", fields: [parentAppointmentId], references: [id])
  followUps           Appointment[] @relation("FollowUps")
  isFollowUp          Boolean        @default(false)
  followUpStatus      String?        // Free Follow-up, Paid Follow-up
  paymentStatus       String?        // Paid, Free, Unpaid
  followUpPaymentStatus String?   // Keep for compatibility or remove later
  serviceIds      String[]       @default([])
  invoice         Invoice?
  // Therapy Consultation linkage
  consultationId  String?
  therapyPlanId   String?
  therapyPlan     TherapyPlan?   @relation("TherapyPlanAppointments", fields: [therapyPlanId], references: [id], onDelete: SetNull)
  sessionNumber   Int?           // e.g. session 2 of 10
  consultation    Consultation?  @relation("ConsultationAppointment")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([clinicId])
  @@index([patientId])
  @@index([doctorId])
  @@index([scheduledAt])
  @@index([status])
  @@index([therapyPlanId])
}

model Service {
  id               String          @id @default(uuid())
  serviceName      String
  serviceCode      String?
  serviceType      String?         @default("regular") // "regular" | "therapy"
  description      String?
  gallery          String[]
  minSessions      Int?
  maxSessions      Int?
  sessionGap       Int?
  scheduleType     String? // "daily" | "alternate" | "weekly" | "custom"
  customDates      Json?
  departmentId     String?
  department       Department?     @relation(fields: [departmentId], references: [id])
  specializationId String?
  specialization   Specialization? @relation(fields: [specializationId], references: [id])
  price            Float?
  duration         String?
  status           String          @default("Active")
  clinicId         String
  clinic           Clinic          @relation(fields: [clinicId], references: [id])
  invoiceItems     InvoiceItem[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([clinicId])
  @@index([departmentId])
  @@index([specializationId])
  @@index([status])
}

model Specialization {
  id                 String   @id @default(uuid())
  name               String
  description        String?
  image              String?
  status             String   @default("Active")
  specializationType String?  @default("regular")
  clinicId           String
  clinic             Clinic   @relation(fields: [clinicId], references: [id])
  doctors            Doctor[]
  services           Service[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([clinicId])
  @@index([status])
}

model Holiday {
  id          String    @id @default(uuid())
  title       String
  description String?
  date        DateTime
  endDate     DateTime?
  dayName     String?
  clinicId    String
  clinic      Clinic    @relation(fields: [clinicId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clinicId])
}

model Payroll {
  id               String   @id @default(uuid())
  staffId          String?
  staff            Staff?    @relation(fields: [staffId], references: [id])
  doctorId         String?
  doctor           Doctor?   @relation(fields: [doctorId], references: [id])
  netSalary        Float
  basicSalary      Float    @default(0)
  da               Float    @default(0)
  hra              Float    @default(0)
  conveyance       Float    @default(0)
  medicalAllowance Float    @default(0)
  otherEarnings    Float    @default(0)
  tds              Float    @default(0)
  esi              Float    @default(0)
  pf               Float    @default(0)
  profTax          Float    @default(0)
  labourWelfare    Float    @default(0)
  otherDeductions  Float    @default(0)
  status           String   @default("Paid")
  salaryDate       DateTime @default(now())
  clinicId         String
  clinic           Clinic   @relation(fields: [clinicId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([clinicId])
  @@index([staffId])
  @@index([doctorId])
}

model Expense {
  id            String   @id @default(uuid())
  name          String
  category      String
  amount        Float
  date          DateTime
  purchasedBy   String
  paymentMethod String
  status        String   @default("New")
  clinicId      String
  clinic        Clinic   @relation(fields: [clinicId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([clinicId])
}

model ExpenseCategory {
  id        String   @id @default(uuid())
  name      String
  status    String   @default("Active")
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
}

model ClinicRole {
  id          String   @id @default(uuid())
  name        String
  permissions Json     @default("[]")
  status      String   @default("Active")
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clinicId])
}

model Attendance {
  id           String   @id @default(uuid())
  date         DateTime
  employeeId   String
  employeeType String // "DOCTOR" or "STAFF"
  status       String // "PRESENT", "ABSENT", "HALF_DAY"
  markedBy     String   @default("ADMIN") // "ADMIN", "SELF", "SYSTEM"
  clinicId     String
  clinic       Clinic   @relation(fields: [clinicId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([clinicId, employeeId, employeeType, date])
  @@index([clinicId])
  @@index([employeeId])
}

model LeaveType {
  id        String   @id @default(uuid())
  name      String
  quota     Int      @default(0)
  status    String   @default("Active")
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
}

model Leave {
  id            String   @id @default(uuid())
  clinicId      String
  clinic        Clinic   @relation(fields: [clinicId], references: [id])
  employeeId    String
  employeeType  String // DOCTOR or STAFF
  leaveTypeId   String
  leaveTypeName String
  subject       String?
  evidenceFiles Json?    @default("[]")
  isPaid        Boolean  @default(false)
  startDate     DateTime
  endDate       DateTime
  days          Int      @default(1)
  workingDays   Int      @default(1)
  reason        String?  @default("")
  status        String   @default("APPLIED") // APPLIED, APPROVED, REJECTED, COMPLETED, WITHDRAWN, CANCELLED
  rejectRemark  String?
  adminNotes    String?
  appliedOn     DateTime @default(now())
  completedAt   DateTime?
  withdrawnAt   DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([clinicId])
  @@index([employeeId])
}

model WorkingDaysConfig {
  id          String   @id @default(uuid())
  clinicId    String   @unique
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  offDays     Int[]    @default([0]) // Array of days (0 = Sunday, 1 = Monday, etc.)
  schedules   Json?    @default("[]") // [{ day: 0, startTime: "09:00", endTime: "18:00", isActive: false }, ...]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Prescription {
  id               String       @id @default(uuid())
  prescriptionCode String?
  patientId        String?
  patient          Patient?     @relation(fields: [patientId], references: [id], onDelete: SetNull)
  doctorId         String?
  doctor           Doctor?      @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  appointmentId    String?
  appointment      Appointment? @relation(fields: [appointmentId], references: [id])
  departmentId     String?
  department       Department?  @relation(fields: [departmentId], references: [id])
  advice           String?
  followUpDate     DateTime?
  followUpNotes    String?
  status           String       @default("Active")
  clinicId         String
  clinic           Clinic       @relation(fields: [clinicId], references: [id])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  medicines PrescriptionMedicine[]
  diagnosticTests Json?

  @@index([clinicId])
  @@index([patientId])
  @@index([doctorId])
}

model PrescriptionMedicine {
  id             String       @id @default(uuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicineName   String
  dosage         String?
  strength       String?
  frequency      String?
  duration       String?
  timings        String? // e.g., "After meal", "Before meal"
  clinicId       String
  clinic         Clinic       @relation(fields: [clinicId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([prescriptionId])
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceCode   String?
  patientId     String?
  patient       Patient?      @relation(fields: [patientId], references: [id], onDelete: SetNull)
  invoiceDate   DateTime
  dueDate       DateTime
  tax           Float         @default(0)
  discount      Float         @default(0)
  subTotal      Float         @default(0)
  totalAmount   Float
  amountPaid    Float         @default(0)
  paymentMethod String?
  paymentStatus String        @default("Pending") // Pending, Paid, Partially Paid
  otherInfo     String?
  clinicId      String
  clinic        Clinic        @relation(fields: [clinicId], references: [id])
  items         InvoiceItem[]
  appointmentId String?       @unique
  appointment   Appointment?  @relation(fields: [appointmentId], references: [id])
  labBookingId  String?       @unique
  labBooking    LabBooking?   @relation(fields: [labBookingId], references: [id])
  consultationId String?      @unique
  consultation  Consultation? @relation(fields: [consultationId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([clinicId])
  @@index([patientId])
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  serviceId   String?
  service     Service? @relation(fields: [serviceId], references: [id])
  description String?
  quantity    Int      @default(1)
  unitCost    Float
  amount      Float
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([invoiceId])
  @@index([serviceId])
  @@index([clinicId])
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  key         String?
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clinicId])
}

model Notification {
  id           String   @id @default(uuid())
  clinicId     String?
  clinic       Clinic?  @relation(fields: [clinicId], references: [id])
  type         String   // APPOINTMENT | INVOICE | DOCTOR_ADDED | PATIENT_ADDED | PRESCRIPTION | GENERAL | CLINIC_REGISTERED
  title        String
  message      String
  targetRole   String   @default("ALL") // ALL | ADMIN | DOCTOR | PATIENT | SUPER_ADMIN
  targetUserId String?
  link         String?
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([clinicId])
  @@index([targetUserId])
  @@index([isRead])
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
}

model DemoBooking {
  id          String   @id @default(uuid())
  name        String?
  email       String
  phone       String
  location    String?
  clinicName  String?
  dateTime    DateTime?
  status      String   @default("Pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Ticket {
  id          String   @id @default(uuid())
  ticketCode  String?
  subject     String
  description String
  priority    String   @default("Medium") // Low, Medium, High
  status      String   @default("Pending") // Pending, In Progress, Solved
  clinicId    String?
  clinic      Clinic?  @relation(fields: [clinicId], references: [id])
  userId      String?
  userName    String?
  userEmail   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

model Todo {
  id        String   @id @default(uuid())
  title     String
  priority  String   @default("Medium") // Low, Medium, High
  status    String   @default("Pending") // Pending, Completed
  taskDate  DateTime?
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@index([status])
}

model Note {
  id            String       @id @default(uuid())
  title         String
  content       String?
  priority      String       @default("Medium") // Low, Medium, High
  noteDate      DateTime?
  clinicId      String
  clinic        Clinic       @relation(fields: [clinicId], references: [id])
  userId        String?
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([clinicId])
  @@index([appointmentId])
}

// ============ PATHLAB MODELS ============

model LabCategory {
  id          String    @id @default(uuid())
  name        String
  description String?
  status      String    @default("Active")
  clinicId    String
  clinic      Clinic    @relation(fields: [clinicId], references: [id])
  tests       LabTest[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clinicId])
}

model LabTest {
  id                    String      @id @default(uuid())
  testCode              String?
  name                  String
  shortName             String?
  description           String?
  price                 Float       @default(0)
  homeCollectionCharge  Float?      @default(0)
  duration              String?
  preparationInfo       String?
  assignment            String?     @default("Staff") // Doctor, Staff, Multiple
  assignedDoctors       Json?
  assignedStaff         Json?
  status                String      @default("Active")
  schedules             Json?
  isSlotBookingEnabled  Boolean     @default(false)
  slotDuration          Int?
  maxBookingsPerSlot    Int?
  categoryId            String?
  category    LabCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  clinicId    String
  clinic      Clinic      @relation(fields: [clinicId], references: [id])
  bookings    LabBooking[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([clinicId])
  @@index([categoryId])
}

model LabBooking {
  id              String    @id @default(uuid())
  bookingCode     String?
  patientId       String?
  patient         Patient?  @relation(fields: [patientId], references: [id], onDelete: SetNull)
  testId          String?
  test            LabTest?  @relation(fields: [testId], references: [id], onDelete: SetNull)
  scheduledAt     DateTime
  status          String    @default("Pending") // Pending, Completed, Cancelled
  paymentStatus   String    @default("Unpaid")  // Paid, Unpaid, Partial
  paymentMethod   String?
  discount        Float     @default(0)
  tax             Float     @default(0)
  totalAmount     Float     @default(0)
  invoiceNo       String?
  sessionSlot     String?
  assignedUserId  String?
  remarks         String?
  referredBy      String?
  testsList       Json?
  clinicId        String
  clinic          Clinic    @relation(fields: [clinicId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  invoice         Invoice?

  @@index([clinicId])
  @@index([patientId])
  @@index([testId])
  @@index([status])
}

// ============ PHARMACY MODELS ============

model PharmacyCategory {
  id          String     @id @default(uuid())
  name        String
  description String?
  status      String     @default("Active")
  clinicId    String
  clinic      Clinic     @relation(fields: [clinicId], references: [id])
  medicines   Medicine[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([clinicId])
}

model Medicine {
  id                  String            @id @default(uuid())
  // Basic Information
  medicineName        String
  genericName         String?
  brandName           String?
  categoryId          String?
  category            PharmacyCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  manufacturer        String?
  medicineCode        String?           // SKU
  hsnCode             String?
  description         String?
  // Pricing
  purchasePrice       Float             @default(0)
  sellingPrice        Float             @default(0)
  gst                 Float             @default(0)
  mrp                 Float             @default(0)
  // Stock Information
  openingStock        Int               @default(0)
  stockIn             Int               @default(0)
  stockOut            Int               @default(0)
  minimumStockAlert   Int               @default(0)
  unit                String?           // Strip, Tablet, Bottle, etc.
  // Batch Information
  batchNumber         String?
  manufacturingDate   DateTime?
  expiryDate          DateTime?
  // Additional
  prescriptionRequired Boolean          @default(false)
  status              String            @default("Active")
  clinicId            String
  clinic              Clinic            @relation(fields: [clinicId], references: [id])
  invoiceItems        PharmacyInvoiceItem[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([clinicId])
  @@index([categoryId])
  @@index([status])
}

model PharmacyInvoice {
  id              String                @id @default(uuid())
  invoiceNo       String                @unique
  patientId       String?
  patient         Patient?              @relation(fields: [patientId], references: [id], onDelete: SetNull)
  customerName    String?               // For walk-in customers
  customerPhone   String?               // For walk-in customers
  invoiceDate     DateTime              @default(now())
  tax             Float                 @default(0)
  discount        Float                 @default(0)
  subTotal        Float                 @default(0)
  totalAmount     Float
  paymentMethod   String                @default("Cash") // Cash, Card, UPI, etc.
  paymentStatus   String                @default("Paid") // Paid, Unpaid
  clinicId        String
  clinic          Clinic                @relation(fields: [clinicId], references: [id])
  items           PharmacyInvoiceItem[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([clinicId])
  @@index([patientId])
}

model PharmacyInvoiceItem {
  id              String          @id @default(uuid())
  invoiceId       String
  invoice         PharmacyInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  medicineId      String?
  medicine        Medicine?       @relation(fields: [medicineId], references: [id], onDelete: SetNull)
  medicineName    String          // snapshot
  quantity        Int
  unitCost        Float
  gst             Float           @default(0)
  amount          Float
  clinicId        String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([invoiceId])
  @@index([medicineId])
}

// ============================================================
// THERAPY CONSULTATION MODULE
// ============================================================

model Consultation {
  id                   String        @id @default(uuid())
  consultationCode     String?
  appointmentId        String        @unique
  appointment          Appointment   @relation("ConsultationAppointment", fields: [appointmentId], references: [id], onDelete: Cascade)
  patientId            String?
  patient              Patient?      @relation(fields: [patientId], references: [id], onDelete: SetNull)
  doctorId             String?
  doctor               Doctor?      @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  clinicId             String
  clinic               Clinic        @relation(fields: [clinicId], references: [id])

  // Step 1 – Examination
  examinationNotes     String?
  bodyPoints           Json?         // [{ part, label, remark, severity, daysSince }]

  // Therapy Plans
  therapyPlans         TherapyPlan[]

  // Pricing
  consultationFee      Float         @default(0)
  discountType         String?       // "percentage" | "fixed" | "none"
  discountValue        Float?
  discountAmount       Float?        @default(0)
  therapyTotalAmount   Float?        @default(0)
  finalTotalAmount     Float?        @default(0)
  amountPaid           Float?        @default(0)
  paymentMethod        String?       // Cash, Card, UPI
  paymentStatus        String        @default("Unpaid") // Unpaid, Partial Paid, Paid

  // Notifications
  whatsappNotification Boolean?      @default(false)

  status               String        @default("Draft") // Draft, Confirmed

  // Invoice (one master invoice for entire consultation)
  invoice              Invoice?

  // Prescription & Advice
  medicines            Json?         // [{ name, dosage, duration, instructions }]
  advice               String?
  painLevel            Int?          // 1–10 pain scale
  attachments          Json?         // [{ url, remark }]

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([clinicId])
  @@index([patientId])
  @@index([doctorId])
  @@index([appointmentId])
}

model TherapyPlan {
  id                 String        @id @default(uuid())
  consultationId     String
  consultation       Consultation  @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  clinicId           String
  clinic             Clinic        @relation(fields: [clinicId], references: [id])

  therapyId          String?
  therapyName        String?
  therapyCategoryId  String?
  therapyCategoryName String?
  totalSessions      Int           @default(1)
  sessionFee         Float         @default(0)
  startDate          DateTime?
  sessionTime        String?       // HH:mm – optional preferred slot time
  scheduleType       String        @default("daily") // daily | alternate | weekly | custom
  customDates        Json?         // used when scheduleType=custom
  notes              String?

  // Auto-created child appointments
  childAppointments  Appointment[] @relation("TherapyPlanAppointments")

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([consultationId])
  @@index([clinicId])
}
